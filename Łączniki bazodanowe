-- 1. Utworzenie łącznika bazodanowego do filii (Uruchom w bazie 11a)
CREATE DATABASE LINK dblinkFilia 
CONNECT TO RBDN2_ST13 IDENTIFIED BY "start123"
USING 'baza11b';

-- 2. Wyświetlenie tabeli z filii za pomocą łącznika
SELECT * FROM kursanci@dblinkFilia;

-- 3. Tworzenie synonimów lokalnych (Baza 11a)
CREATE SYNONYM kursanciSiedziba FOR kursanci;
CREATE SYNONYM wykladowcySiedziba FOR wykladowcy;
CREATE SYNONYM rodzajeSiedziba FOR rodzaje;
CREATE SYNONYM kursySiedziba FOR kursy;

-- 4. Tworzenie synonimów zdalnych poprzez łącznik (Baza 11a)
CREATE SYNONYM kursanciFilia FOR kursanci@dblinkFilia;
CREATE SYNONYM wykladowcyFilia FOR wykladowcy@dblinkFilia;
CREATE SYNONYM rodzajeFilia FOR rodzaje@dblinkFilia;
CREATE SYNONYM kursyFilia FOR kursy@dblinkFilia;

-- 5. Tworzenie widoków łączących uczestników i wykładowców (Baza 11a)
CREATE OR REPLACE VIEW kursanciAll AS 
SELECT imie, nazwisko FROM kursanciSiedziba
UNION 
SELECT imie, nazwisko FROM kursanciFilia;

CREATE OR REPLACE VIEW wykladowcyAll AS 
SELECT imie, nazwisko FROM wykladowcySiedziba
UNION 
SELECT imie, nazwisko FROM wykladowcyFilia;

-- 6. Tworzenie widoku kursyAll (ilość uczestników na podstawie umów w bazie 11a)
CREATE OR REPLACE VIEW kursyAll AS 
SELECT r.nazwa AS nazwa_kursu, w.imie || ' ' || w.nazwisko AS prowadzacy, COUNT(u.umowa_id) AS ilosc_uczestnikow, 
       r.cena, r.godz, w.stawka, 'SIEDZIBA' as lokalizacja
FROM kursySiedziba k
JOIN rodzajeSiedziba r ON k.rodzaj_id = r.rodzaj_id
JOIN wykladowcySiedziba w ON k.wykladowca_id = w.wykladowca_id
LEFT JOIN umowy u ON k.kurs_id = u.kurs_id
GROUP BY r.nazwa, w.imie, w.nazwisko, r.cena, r.godz, w.stawka
UNION ALL
SELECT r.nazwa AS nazwa_kursu, w.imie || ' ' || w.nazwisko AS prowadzacy, COUNT(u.umowa_id) AS ilosc_uczestnikow, 
       r.cena, r.godz, w.stawka, 'FILIA' as lokalizacja
FROM kursyFilia k
JOIN rodzajeFilia r ON k.rodzaj_id = r.rodzaj_id
JOIN wykladowcyFilia w ON k.wykladowca_id = w.wykladowca_id
LEFT JOIN umowy u ON k.kurs_id = u.kurs_id
GROUP BY r.nazwa, w.imie, w.nazwisko, r.cena, r.godz, w.stawka;

-- 7. Wyliczenia na widoku kursyAll
-- Przychód ze wszystkich kursów
SELECT SUM(cena * ilosc_uczestnikow) AS calkowity_przychod FROM kursyAll;

-- Koszty (stawka * liczba godzin) ze wszystkich kursów, na które zapisani są uczestnicy
SELECT SUM(stawka * godz) AS calkowite_koszty FROM kursyAll WHERE ilosc_uczestnikow > 0;

-- Zysk/Strata dla każdego kursu
SELECT nazwa_kursu, prowadzacy, lokalizacja, 
       (cena * ilosc_uczestnikow) - (stawka * godz) AS zysk_strata 
FROM kursyAll;

-- Łączny zysk dla wszystkich kursów ogółem
SELECT SUM((cena * ilosc_uczestnikow) - (stawka * godz)) AS laczny_zysk FROM kursyAll;
